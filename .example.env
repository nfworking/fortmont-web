DATABASE_URL=mysql://username:password@host:port/database_name
AUTH_MICROSOFT_ENTRA_ID_ID=your_client_id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your_client_secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your_tenant_id
AUTH_SECRET=your_auth_secret (generate with npx auth secret)
PROXMOX_API_TOKEN=your_proxmox_api_token (Used for Proxmox RealTime Info only in fortmont Mobile)'
DNS_API_TOKEN=your_dns_api_token (Used for DNS Records in fortmont Mobile and future dashboard features)'