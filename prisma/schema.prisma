// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// DEPRECIATED REMOVE 
model lxc {
  lxc_unique_id     String   @id @default(uuid())
  lxc_ip            String
  lxc_role          String
  lxc_status        String
  lxc_compose_status String
  created_at        DateTime @default(now())
}

// DEPRECIATED REMOVE
model registry {
  id   String @id @default(uuid())
  name String
  version String
  hosted_on String 
  server_url String?
}


// CORE SCHEMA MODEL FOR FORTMONT USERS
model AppUsers {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String?
  email        String?  @unique
  role         String?
  avatarUrl    String?
  phone        String?
  isEntraUser  Boolean? @default(false)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  onboarded    Boolean? @default(false)


  mailboxes    UserMailbox[]
  deviceTokens DeviceToken[]
  passwordResetTokens PasswordResetToken[]
  createdTickets  Tickets[] @relation("TicketCreator")
  assignedTickets Tickets[] @relation("TicketAssignee")

}

// PASSWORD RESET FOR USERS
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user      AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//MOBILE DEVICE SCHEMA FOR USERS 
model DeviceToken {
  id        String   @id @default(uuid())
  token     String   @unique // The unique token generated by Firebase on the mobile app
  platform  String   // 'ios' or 'android'
  deviceVersion String?
  deviceName String?
  deviceModelName String?
  deviceBrand String?
  userId    String
  user      AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

//USER MAILBOX SCHEMA FOR MAIL CLIENT
model UserMailbox {
  id                String   @id @default(uuid())

  userId            String
  email             String   // mailbox address (can differ from AppUsers.email)
  

  encryptedPassword String

  isPrimary         Boolean  @default(true)
  provider          String?  // "mailcow", "external", etc.

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

//SCHEMA FOR APPS DASHBOARD
model Apps {
id                String   @id @default(uuid())
label             String
description       String?
url               String

}


model KbArticle {
  id          String   @id @default(uuid())

  title       String
  slug        String   @unique

  content     String   @db.Text

  published   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tickets {
  id          String         @id @default(uuid())
  type        String
  department  String
  subject     String
  description String
  priority    TicketPriority
  status      String?

  // who created it
  createdById String?
  createdBy   AppUsers? @relation("TicketCreator", fields: [createdById], references: [id])

  // who it's assigned to
  assignedToId String?
  assignedTo   AppUsers? @relation("TicketAssignee", fields: [assignedToId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}