// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// CORE SCHEMA MODEL FOR FORTMONT USERS
model AppUsers {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String?
  email        String?  @unique
  role         String?
  avatarUrl    String?  @default("/defaults/profile_default.jpg")
  phone        String?
  isEntraUser  Boolean? @default(false)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  onboarded    Boolean? @default(false)
  lastLoggedIn DateTime @default(now())

  // RELATIONS
  mailboxes           UserMailbox[]
  deviceTokens        DeviceToken[]
  passwordResetTokens PasswordResetToken[]
  createdTickets      Tickets[]            @relation("TicketCreator")
  assignedTickets     Tickets[]            @relation("TicketAssignee")
  teams               Team[]
  comments            Comment[]
  githubLink          GitHubLink[]
  notifications       Notifications[]
  sessions            UserSession[]
  platformApiKeys     PlatformApiKey[]
  files               File[]
  storage             UserStorage?
  fileActivities      FileActivity[]
  pendingUploads      PendingUpload[]
}

model GitHubLink {
  id          String   @id @default(cuid())
  userId      String   @unique
  githubId    String   @unique
  username    String
  accessToken String
  tokenType   String   @default("bearer")
  scope       String?
  avatarUrl   String?
  profileUrl  String?
  linkedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("github_links")
}

// NOTIFICATIONS
model Notifications {
  id          String @id @default(uuid())
  type        String
  title       String
  description String

  createdAt DateTime @default(now())
  read      Boolean? @default(false)
  userId    String
  user      AppUsers @relation(fields: [userId], references: [id])
}

// PASSWORD RESET FOR USERS
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// MOBILE DEVICE SCHEMA FOR USERS 
model DeviceToken {
  id              String   @id @default(uuid())
  token           String   @unique
  platform        String
  deviceVersion   String?
  deviceName      String?
  deviceModelName String?
  deviceBrand     String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// USER MAILBOX SCHEMA FOR MAIL CLIENT
model UserMailbox {
  id                String   @id @default(uuid())
  userId            String
  email             String
  encryptedPassword String
  isPrimary         Boolean  @default(true)
  provider          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

// SCHEMA FOR APPS DASHBOARD
model Apps {
  id          String  @id @default(uuid())
  label       String
  description String?
  url         String
}

// TICKETING PLATFORM SPECIFICS
model KbArticle {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tickets {
  id           String         @id @default(uuid())
  type         String
  department   String
  subject      String
  description  String         @db.LongText
  priority     TicketPriority
  status       String?
  teamId       String?
  createdById  String?
  assignedToId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdBy  AppUsers? @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo AppUsers? @relation("TicketAssignee", fields: [assignedToId], references: [id])
  team       Team?     @relation(fields: [teamId], references: [id])
  comments   Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  ticketId  String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket Tickets  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author AppUsers @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
}

model Team {
  id          String     @id @default(uuid())
  name        String
  description String?
  members     AppUsers[]
  tickets     Tickets[]
}

model UserSession {
  id            String   @id @default(uuid())
  userId        String
  sessionToken  String   @unique
  userAgent     String?  @db.Text
  ipAddress     String?
  cookieVersion Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastActive    DateTime @default(now())
  expiresAt     DateTime

  user AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model PlatformApiKey {
  id           String   @id @default(cuid())
  userId       String
  name         String
  prefix       String
  keyHash      String   @unique
  scopes       Json
  usageCount   Int      @default(0)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("platform_api_keys")
}

model File {
  id String @id @default(uuid())

  // ownership
  ownerId String
  owner   AppUsers @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // storage backend
  bucket    String
  objectKey String @unique

  // file metadata
  name     String
  size     BigInt
  mimeType String?

  // relationships (important for your platform)
  ticketId String?
  assetId  String?

  // folder system (simple path-based)
  folderPath String?

  // sharing
  isPublic Boolean @default(false)

  // lifecycle
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  fileShares     FileShare[]
  fileActivities FileActivity[]

  @@index([ownerId])
  @@index([ticketId])
  @@index([assetId])
}

model UserStorage {
  userId String   @id
  user   AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  quotaBytes BigInt @default(1073741824) // 1GB default
  usedBytes  BigInt @default(0)

  updatedAt DateTime @updatedAt

  @@index([userId])
}

model FileShare {
  id String @id @default(uuid())

  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  token String @unique

  expiresAt DateTime?
  password  String?

  createdAt DateTime @default(now())

  @@index([fileId])
}

model FileActivity {
  id String @id @default(uuid())

  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  userId String
  user   AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  action String // UPLOAD, DOWNLOAD, DELETE, MOVE, RENAME

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([userId])
}

model PendingUpload {
  id        String  @id @default(uuid())
  userId    String
  objectKey String  @unique
  fileName  String
  fileSize  BigInt
  mimeType  String?
  ticketId  String?

  createdAt DateTime @default(now())

  user AppUsers @relation(fields: [userId], references: [id])

  @@index([userId])
}
